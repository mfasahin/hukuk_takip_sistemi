@model IEnumerable<Presentation.Models.AvukatModel>
@{
    ViewBag.Title = "Avukat Listesi";
}
<!-- Avukat Ekle Butonu -->
<tr>
    <td colspan="6">
        <div style="display:flex; justify-content:flex-end;">
            <button type="button" class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                Avukat Ekle
            </button>
        </div>
    </td>
</tr>

<!-- Avukat Listesi -->
<h2>Avukatlar</h2>
<table class="table">
    <thead>
        <tr>
            <th>
                <!-- Tümünü seç/deselect için -->
                <input type="checkbox" id="selectAll" />
            </th>
            <th>Ad</th>
            <th>Soyad</th>
            <th>TBB Sicil No</th>
            <th>Telefon</th>
            <th>E_POSTA</th>
            <th>HUKUK BRÜ AD</th>
            <th>HUKUK BÜRO ADRES</th>
            <th>OFİS TELEFON NUMARASI</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var avukat in Model)
        {
            <tr>
                <td>
                    <input type="checkbox" class="rowCheckbox" value="@avukat.AVUKAT_ID" />
                </td>
                <td>@avukat.AVKT_AD</td>
                <td>@avukat.AVKT_SOYAD</td>
                <td>@avukat.TBB_SICIL_NO</td>
                <td>@avukat.AVKT_TEL_NO</td>
                <td>@avukat.AVKT_EPOSTA</td>
                <td>@avukat.HKK_BURO_AD</td>
                <td>@avukat.HKK_BURO_ADRES</td>
                <td>@avukat.OFIS_TEL_NO</td>
                <td>
                    <button class="btn btn-primary updateBtn" data-id="@avukat.AVUKAT_ID">
                        Güncelle
                    </button>
                    <button class="btn btn-danger deleteBtn" data-id="@avukat.AVUKAT_ID">
                        Sil
                    </button>

                </td>
            </tr>
        }
    </tbody>
</table>

@Html.Partial("_AvukatModals")

@section Scripts {
    <script src="~/Scripts/crud.js"></script>
    <script>
        initCrud("Avukat", ["AVUKAT_ID", "AVKT_AD", "AVKT_SOYAD", "TBB_SICIL_NO", "AVKT_EPOSTA", "AVKT_TEL_NO", "HKK_BURO_AD", "HKK_BURO_ADRES", "OFIS_TEL_NO"]);
    </script>
}