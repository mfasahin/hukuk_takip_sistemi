@model IEnumerable<Presentation.Models.AvukatModel>
@{
    ViewBag.Title = "Avukat Listesi";
}
<!-- Avukat Ekle Butonu -->
<tr>
    <td colspan="6">
        <div style="display:flex; justify-content:flex-end;">
            <button type="button" class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                Avukat Ekle
            </button>
        </div>
    </td>
</tr>

<!-- Avukat Listesi -->
<h2>Avukatlar</h2>
<table class="table">
    <thead>
        <tr>
            <th>
                <!-- Tümünü seç/deselect için -->
                <input type="checkbox" id="selectAll" />
            </th>
            <th>Ad</th>
            <th>Soyad</th>
            <th>TBB Sicil No</th>
            <th>Telefon</th>
            <th>E_POSTA</th>
            <th>HUKUK BRÜ AD</th>
            <th>HUKUK BÜRO ADRES</th>
            <th>OFİS TELEFON NUMARASI</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var avukat in Model)
        {
            <tr>
                <td>
                    <input type="checkbox" class="rowCheckbox" value="@avukat.AvukatId" />
                </td>
                <td>@avukat.AvktAd</td>
                <td>@avukat.AvktSoyad</td>
                <td>@avukat.TbbSicilNo</td>
                <td>@avukat.AvktTelNo</td>
                <td>@avukat.AvktEposta</td>
                <td>@avukat.HkkBuroAd</td>
                <td>@avukat.HkkBuroAdres</td>
                <td>@avukat.OfisTelNo</td>
                <td>
                    <button class="btn btn-primary updateBtn" data-id="@avukat.AvukatId">
                        Güncelle
                    </button>
                    <button class="btn btn-danger deleteBtn" data-id="@avukat.AvukatId">
                        Sil
                    </button>

                </td>
            </tr>
        }
    </tbody>
</table>

@Html.Partial("_AvukatModals")

@section Scripts {
    <script src="~/Scripts/crud.js"></script>
    <script>
        initCrud("Avukat", ["AvukatId", "AvktAd", "AvktSoyad", "TbbSicilNo", "AvktEposta", "AvktTelNo", "HkkBuroAd", "HkkBuroAdres", "OfisTelNo"]);
    </script>
}