@model IEnumerable<Presentation.Models.AvukatModel>


<!-- Avukat Ekle Butonu -->
<tr>
    <td colspan="6">
        <div style="display:flex; justify-content:flex-end;">
            <button type="button" class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                Avukat Ekle
            </button>
        </div>
    </td>
</tr>

<!-- Avukat Listesi -->
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ad</th>
            <th>Soyad</th>
            <th>TBB Sicil No</th>
            <th>Telefon</th>
            <th>E_POSTA</th>
            <th>HUKUK BRÜ AD</th>
            <th>HUKUK BÜRO ADRES</th>
            <th>OFİS TELEFON NUMARASI</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var avukat in Model)
        {
            <tr>
                <td>@avukat.AVUKAT_ID</td>
                <td>@avukat.AVKT_AD</td>
                <td>@avukat.AVKT_SOYAD</td>
                <td>@avukat.TBB_SICIL_NO</td>
                <td>@avukat.AVKT_TEL_NO</td>
                <td>@avukat.AVKT_EPOSTA</td>
                <td>@avukat.HKK_BURO_AD</td>
                <td>@avukat.HKK_BURO_ADRES</td>
                <td>@avukat.OFIS_TEL_NO</td>
                <td>
                    <button class="btn btn-primary updateBtn" data-id="@avukat.AVUKAT_ID">
                        Güncelle
                    </button>
                    <button class="btn btn-danger deleteBtn" data-id="@avukat.AVUKAT_ID">
                        Sil
                    </button>

                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Avukat Ekle Modal -->
<div class="modal fade" id="createModal" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Avukat Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createForm">
                    <div class="form-group">
                        <label>Ad</label>
                        <input type="text" class="form-control" name="AVKT_AD" />
                    </div>
                    <div class="form-group">
                        <label>Soyad</label>
                        <input type="text" class="form-control" name="AVKT_SOYAD" />
                    </div>
                    <div class="form-group">
                        <label>Sicil No</label>
                        <input type="text" class="form-control" name="TBB_SICIL_NO" />
                    </div>
                    <div class="form-group">
                        <label>E-posta</label>
                        <input type="text" class="form-control" name="AVKT_EPOSTA" />
                    </div>
                    <div class="form-group">
                        <label>Telefon</label>
                        <input type="text" class="form-control" name="AVKT_TEL_NO" />
                    </div>
                    <button type="button" id="createSaveBtn" class="btn btn-success">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Avukat Güncelle Modal -->
<div class="modal fade" id="updateModal" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Avukat Güncelle</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="updateForm">
                    <input type="hidden" id="AVUKAT_ID" name="AVUKAT_ID" />
                    <div class="form-group">
                        <label>Ad</label>
                        <input type="text" class="form-control" id="AVKT_AD" name="AVKT_AD" />
                    </div>
                    <div class="form-group">
                        <label>Soyad</label>
                        <input type="text" class="form-control" id="AVKT_SOYAD" name="AVKT_SOYAD" />
                    </div>
                    <div class="form-group">
                        <label>Sicil No</label>
                        <input type="text" class="form-control" id="TBB_SICIL_NO" name="TBB_SICIL_NO" />
                    </div>
                    <div class="form-group">
                        <label>Telefon</label>
                        <input type="text" class="form-control" id="AVKT_TEL_NO" name="AVKT_TEL_NO" />
                    </div>
                    <div class="form-group">
                        <label>e_posta</label>
                        <input type="text" class="form-control" id="AVKT_EPOSTA" name="AVKT_EPOSTA" />
                    </div>
                    <button type="button" id="saveBtn" class="btn btn-success">Kaydet</button>

                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {

    <script>

        // Yeni avukat ekleme
        $(document).on("click", "#createSaveBtn", function () {
            $("#createForm").submit();
        });

        // Form submit olunca AJAX çalışır
        $("#createForm").on("submit", function (e) {
            e.preventDefault(); // Sayfanın yenilenmesini engelle

            $.ajax({
                url: '/Avukat/Create',      // Controller'daki Create action
                type: 'POST',
                data: $(this).serialize(),  // Formdaki inputları gönder
                success: function (result) {
                    if (result.success) {
                        alert("Avukat eklendi!");
                        $("#createModal").modal("hide"); // Modalı kapat
                        location.reload();               // Listeyi yenile
                    } else {
                        alert("Ekleme başarısız: " + (result.error || ""));
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Hata:", error);
                    alert("Sunucu hatası oluştu!");
                }
            });
        });

        // Avukat Güncelleme
        $(document).on("click", ".updateBtn", function () {
            var id = $(this).data("id");

            $.get('/Avukat/GetAvukat', { id: id }, function (data) {
                $("#AVUKAT_ID").val(data.AVUKAT_ID);
                $("#AVKT_AD").val(data.AVKT_AD);
                $("#AVKT_SOYAD").val(data.AVKT_SOYAD);
                $("#TBB_SICIL_NO").val(data.TBB_SICIL_NO);
                $("#AVKT_TEL_NO").val(data.AVKT_TEL_NO);
                $("#AVKT_EPOSTA").val(data.AVKT_EPOSTA);

                $("#updateModal").modal("show");
            });
        });

        // Kaydet butonuna tıklanınca form submit tetiklenir
        $(document).on("click", "#saveBtn", function () {
            $("#updateForm").submit(); // form submit fonksiyonunu çalıştırır
        });


        $("#updateForm").on("submit", function (e) {
            e.preventDefault();
            $.ajax({
                url: '/Avukat/Update',          // AvukatController içindeki Update action
                type: 'POST',
                data: $(this).serialize(),      // form alanlarını gönder
                success: function (result) {
                    if (result.success) {
                        //messageBox.Show("Güncelleme başarılı!");
                        alert("Güncelleme başarılı!");
                        $("#updateModal").modal("hide");
                        location.reload();
                    } else {
                        alert("Kaydetme başarısız: " + (result.error || ""));
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Hata:", error);
                    alert("Hata oluştu!");
                }
            });
        });

        //silme
        $(document).on("click", ".deleteBtn", function () {
            var id = $(this).data("id");

            if (confirm("Bu kaydı silmek istediğine emin misin?")) {
                $.ajax({
                    url: '/Avukat/Delete',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function (result) {
                        if (result.success) {
                            alert("Kayıt silindi (soft delete)!");
                            location.reload();
                        } else {
                            alert("Silme başarısız: " + (result.error || ""));
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Hata:", error);
                        alert("Hata oluştu!");
                    }
                });
            }
        });


    </script>
}
