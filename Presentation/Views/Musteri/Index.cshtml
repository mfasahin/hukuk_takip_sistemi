@model IEnumerable<Presentation.Models.MusteriModel>
@{
    ViewBag.Title = "Müsteri Listesi";
}

<!-- Müşteri Ekle Butonu -->
<tr>
    <td colspan="6">
        <div style="display:flex; justify-content:flex-end;">
            <button type="button" class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                Müşteri Ekle
            </button>
        </div>
    </td>
</tr>

<h2>Müşteriler</h2>
<table class="table">
    <thead>
        <tr>
            <th>
                <!-- Tümünü seç/deselect için -->
                <input type="checkbox" id="selectAll" />
            </th>
            <th>Müşteri no</th>
            <th>Ad</th>
            <th>Soyad</th>
            <th>kimlik no</th>
            <th>vergi kimlik no</th>
            <th>e_posta</th>
            <th>tel_no</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var musteri in Model)
        {
            <tr>
                <td>
                    <input type="checkbox" class="rowCheckbox" value="@musteri.MUSTERI_ID" />
                </td>
                <td>@musteri.MUST_NO</td>
                <td>@musteri.MUST_AD</td>
                <td>@musteri.MUST_SOYAD</td>
                <td>@musteri.MUST_KIMLIK_NO</td>
                <td>@musteri.MUST_VKNO</td>
                <td>@musteri.MUST_EPOSTA</td>
                <td>@musteri.MUST_TEL_NO</td>
                <td>
                    <button class="btn btn-sm btn-warning updateBtn" data-id="@musteri.MUSTERI_ID">Güncelle</button>
                    <button class="btn btn-sm btn-danger deleteBtn" data-id="@musteri.MUSTERI_ID">Sil</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@Html.Partial("_MusteriModals")

@section Scripts {
    <script src="~/Scripts/crud.js"></script>
    <script>
        initCrud("Musteri", ["MUSTERI_ID", "MUST_NO", "MUST_AD", "MUST_SOYAD", "MUST_KIMLIK_NO", "MUST_VKNO", "MUST_EPOSTA", "MUST_TEL_NO"]);
    </script>

    @*checkbox kontrolü*@
    <!--<script src="~/Scripts/checkbox.js"></script>-->
}