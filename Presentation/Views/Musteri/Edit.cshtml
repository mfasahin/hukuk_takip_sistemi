@model Entity.Concrete.Musteri

<h2>Kullanıcı Güncelle</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(m => m.MUST_ID)

    <div class="form-group">
        @Html.LabelFor(m => m.AdSoyad)
        @Html.TextBoxFor(m => m.AdSoyad, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Eposta)
        @Html.TextBoxFor(m => m.Eposta, new { @class = "form-control" })
    </div>

    <input type="submit" value="Kaydet" class="btn btn-primary" />
    @Html.ActionLink("Geri Dön", "Index")
}
