@model IEnumerable<Presentation.Models.IhtarModel>
@{
    ViewBag.Title = "İhtar Listesi";
}

<h2>İhtarlar</h2>

<div class="mb-3" style="display:flex; justify-content:flex-end;">
    <button type="button" class="btn btn-success"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        İhtar Ekle
    </button>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th>Müşteri</th>
            <th>Borç Tutarı</th>
            <th>İhtar Tarihi</th>
            <th>Şube</th>
            <th>Avukat</th>
            <th>Ürünler</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ihtar in Model)
        {
            <tr>
                <td><input type="checkbox" class="rowCheckbox" value="@ihtar.IhtarId" /></td>
                <td>@ihtar.MusteriAd</td>
                <td>@ihtar.BorcTutar</td>
                <td>@ihtar.IhtarTarZmn.ToString("dd.MM.yyyy")</td>
                <td>@ihtar.SubeAd</td>
                <td>@ihtar.AvukatAd</td>
                <td>
                    @if (ihtar.Urunler != null && ihtar.Urunler.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var urun in ihtar.Urunler)
                            {
                                <li>@urun.UrunAd</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">Ürün yok</span>
                    }
                </td>
                <td>
                    <button class="btn btn-sm btn-warning updateBtn" data-id="@ihtar.IhtarId">Güncelle</button>
                    <button class="btn btn-sm btn-danger deleteBtn" data-id="@ihtar.IhtarId">Sil</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@Html.Partial("_IhtarModals", new Presentation.Models.IhtarModel())

@section Scripts {
    <script src="~/Scripts/crud.js"></script>
    <script>
        // initCrud fonksiyonunda updateBtn ve deleteBtn yakalanmalı
        initCrud("Ihtar", [
            "IhtarId",
            "MusteriId",
            "BorcTutar",
            "IhtarTarZmn",
            "SubeId",
            "AvukatId",
            "SecilenUrunler"
        ]);
    </script>
}
