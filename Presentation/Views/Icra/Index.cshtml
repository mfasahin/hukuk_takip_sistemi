@model IEnumerable<Entity.Dto.IcraDto>
@{
    ViewBag.Title = "İcra Takip";
}

<h2>İcra Takip</h2>

<div style="display:flex; justify-content:flex-end; margin-bottom:10px;">
    <button type="button" class="btn btn-success"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        İcra Ekle
    </button>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th><input type="checkbox" id="selectAll" /></th>
            <th>Müşteri</th>
            <th>Ürün</th>
            <th>Borç Tutarı</th>
            <th>İcra Takip Tarihi</th>
            <th>Mahkeme</th>
            <th>İcra Dosya Numarası</th>
            <th>Avukat</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var icra in Model)
        {
            <tr>
                <td><input type="checkbox" class="rowCheckbox" value="@icra.IcraId" /></td>
                <td>@icra.MusteriAd @icra.MusteriSoyad</td>
                <td>@icra.UrunAd</td>
                <td>@icra.BorcTutar</td>
                <td>@icra.IcraTakipTar.ToString("dd.MM.yyyy")</td>
                <td>@icra.MahkemeAd</td>
                <td>@icra.IcraDosyaNo</td>
                <td>@icra.AvukatAd @icra.AvukatSoyad</td>
                <td>
                    <button class="btn btn-sm btn-warning updateBtn" data-id="@icra.IcraId">Güncelle</button>
                    <button class="btn btn-sm btn-danger deleteBtn" data-id="@icra.IcraId">Sil</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@Html.Partial("_IcraModals", new Entity.Dto.IcraDto())

@section Scripts {
    <script src="~/Scripts/crud.js"></script>
    <script>
        // Ürün dropdown'ını doldurur (1. kademe sonucu)
        function loadUrunOptions(musteriId, prefix, callback) {
            var $urunSelect = $("#" + prefix + "UrunSelect");
            var $ihtarSelect = $("#" + prefix + "IhtarUrunSelect");

            $urunSelect.empty();
            $ihtarSelect.empty().append('<option value="">Önce ürün seçiniz</option>').prop("disabled", true);

            if (!musteriId) {
                $urunSelect.append('<option value="">Önce müşteri seçiniz</option>').prop("disabled", true);
                if (callback) callback();
                return;
            }

            $.get('/Icra/GetUrunlerByMusteri', { musteriId: musteriId })
                .done(function (list) {
                    $urunSelect.append('<option value="">Seçiniz</option>');
                    list.forEach(function (item) {
                        $urunSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                    });
                    $urunSelect.prop("disabled", false);
                    if (callback) callback();
                });
        }

        // İhtar dropdown'ını doldurur (2. kademe sonucu)
        function loadIhtarOptions(musteriId, urunId, prefix, callback) {
            var $ihtarSelect = $("#" + prefix + "IhtarUrunSelect");
            $ihtarSelect.empty();

            if (!urunId) {
                $ihtarSelect.append('<option value="">Önce ürün seçiniz</option>').prop("disabled", true);
                if (callback) callback();
                return;
            }

            $.get('/Icra/GetIhtarlarByMusteriVeUrun', { musteriId: musteriId, urunId: urunId })
                .done(function (list) {
                    $ihtarSelect.append('<option value="">Seçiniz</option>');
                    list.forEach(function (item) {
                        $ihtarSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                    });
                    $ihtarSelect.prop("disabled", false);
                    if (callback) callback();
                });
        }

        // CREATE MODAL kademeleri
        $(document).on("change", "#createMusteriSelect", function () {
            loadUrunOptions($(this).val(), "create");
        });
        $(document).on("change", "#createUrunSelect", function () {
            var musteriId = $("#createMusteriSelect").val();
            loadIhtarOptions(musteriId, $(this).val(), "create");
        });

        // UPDATE MODAL kademeleri
        $(document).on("change", "#updateMusteriSelect", function () {
            loadUrunOptions($(this).val(), "update");
        });
        $(document).on("change", "#updateUrunSelect", function () {
            var musteriId = $("#updateMusteriSelect").val();
            loadIhtarOptions(musteriId, $(this).val(), "update");
        });

        // Create modal her açıldığında sıfırla
        $("#createModal").on("show.bs.modal", function () {
            $("#createMusteriSelect").val("");
            $("#createUrunSelect").empty().append('<option value="">Önce müşteri seçiniz</option>').prop("disabled", true);
            $("#createIhtarUrunSelect").empty().append('<option value="">Önce ürün seçiniz</option>').prop("disabled", true);
        });

        initCrud("Icra", ["IcraId", "MahkemeId", "IcraDosyaNo", "IcraTakipTar"], {
            onGetSuccess: function (data) {
                // 1. Kademe: Müşteriyi seç, ürün listesini yükle
                $("#updateMusteriSelect").val(data.MusteriId);

                loadUrunOptions(data.MusteriId, "update", function () {
                    // 2. Kademe: Ürünü seç, ihtar listesini yükle
                    $("#updateUrunSelect").val(data.UrunId);

                    loadIhtarOptions(data.MusteriId, data.UrunId, "update", function () {
                        // 3. Kademe: Doğru ihtar kaydını seç
                        $("#updateIhtarUrunSelect").val(data.IhtarUrunId);
                    });
                });
            }
        });
    </script>
}