@model IEnumerable<Presentation.Models.UrunModel>
@{
    ViewBag.Title = "Ürün Listesi";
}

<h2>Ürünler</h2>

<!-- Ürün Ekle Butonu -->
<tr>
    <td colspan="6">
        <div style="display:flex; justify-content:flex-end;">
            <button type="button" class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                Ürün Ekle
            </button>
        </div>
    </td>
</tr>

<table class="table">
    <thead>
        <tr>
            <th>
                <!-- Tümünü seç/deselect için -->
                <input type="checkbox" id="selectAll" />
            </th>
            <th>Ürün Adı</th>
            <th>Ürün Kodu</th>
            <th>Ürün Son Geçerlilik Tarihi</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var urun in Model)
        {
            <tr>
                <td>
                    <input type="checkbox" class="rowCheckbox" value="@urun.UrunId" />
                </td>
                <td>@urun.UrunAd</td>
                <td>@urun.UrunKod</td>
                <td>
                    @(urun.SonGecerlilikTar.HasValue
                    ? urun.SonGecerlilikTar.Value.ToString("dd.MM.yyyy")
                    : "")
                </td>


                <td>
                    <button class="btn btn-sm btn-warning updateBtn" data-id="@urun.UrunId">Güncelle</button>
                    <button class="btn btn-sm btn-danger deleteBtn" data-id="@urun.UrunId">Sil</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@Html.Partial("_urunModals")

@section Scripts {
    <script src="~/Scripts/crud.js"></script>
    <script>
        initCrud("Urun", ["UrunId", "UrunAd", "UrunKod", "SonGecerlilikTar"]);
    </script>
}